{
  "description": "Estimates token count for user prompts before submission",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/usage-estimate.mjs",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
